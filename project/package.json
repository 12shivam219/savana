    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "tailwind-merge": "^2.2.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.61.0",
    "@types/dompurify": "^3.0.5",
